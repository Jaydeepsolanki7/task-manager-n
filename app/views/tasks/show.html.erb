<% if notice %>
  <div class="alert alert-success">
    <%= notice %>
  </div>
<% end %>

<div class="card mb-3">
  <div class="card-body">
    <%= render @task %>
  </div>
</div>

<div class="d-flex gap-2" role="group">
  <%= link_to "Edit this task", edit_task_path(@task), class: "btn btn-secondary" %>
  <%= link_to "Back to tasks", tasks_path, class: "btn btn-outline-secondary" %>
  <%= button_to "Destroy this task", @task, method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-danger" %>
</div>
